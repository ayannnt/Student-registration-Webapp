@model EventManagementWebApp.Models.EventInfo
@{
    ViewData["Title"] = "Delete Event";
}

<h3 class="text-danger">Delete Event</h3>
<p>Are you sure you want to delete this event?</p>
<hr />
<table class="table table-striped">
    <tr>
        <td>Event Name</td>
        <td>@Model.EventName</td>
    </tr>
    <tr>
        <td>Event Location</td>
        <td>@Model.EventLocation</td>
    </tr>
    <tr>
        <td>Registered Participants</td>
        <td>@(Model.Participants?.Count ?? 0)</td>
    </tr>
</table>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="EventId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
