@model EventManagementWebApp.Models.Participant
@{
    ViewData["Title"] = "Participant Details";
}

<h3 class="text-primary">Your Registered Details</h3>
<hr />
<table class="table table-striped">
    <tr>
        <td>FullName</td>
        <td>@Model.FullName</td>
    </tr>
    <tr>
        <td>Email</td>
        <td>@Model.Email</td>
    </tr>
    <tr>
        <td>Age</td>
        <td>@Model.Age</td>
    </tr>
    <tr>
        <td>Registered for Event</td>
        <td>@Model.Event.EventName</td>
    </tr>
    <tr>
        <td></td>
        <td>
            <a asp-action="Index" class="btn btn-secondary">Back To List</a>
        </td>
    </tr>
</table>
