@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="text-center mt-5">
    <h1 class="text-danger display-4">⛔ Access Denied</h1>
    <p class="lead">You do not have permission to access this page.</p>
    <p class="text-muted">This page is restricted. If you believe this is a mistake, contact the administrator.</p>
    <a asp-controller="Home" asp-action="Index" asp-area="" class="btn btn-primary mt-3">Go Back Home</a>
</div>
